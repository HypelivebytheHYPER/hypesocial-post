# Post For Me API (Required)
POST_FOR_ME_API_KEY=your_api_key_here
POST_FOR_ME_BASE_URL=https://api.postforme.dev
POST_FOR_ME_WEBHOOK_SECRET=your_webhook_secret

# Authentication
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# Lark Base (Optional - for leaderboard features)
LARK_APP_ID=your_lark_app_id
LARK_APP_SECRET=your_lark_app_secret
LARK_APP_TOKEN=your_lark_app_token
LARK_HTTP_API_URL=https://open.larksuite.com/open-apis
LARK_HTTP_WORKER_URL=your_lark_worker_url

# Lark Table IDs (Optional)
LARK_POSTS_TABLE_ID=your_posts_table_id
LARK_ACCOUNTS_TABLE_ID=your_accounts_table_id
LARK_RESULTS_TABLE_ID=your_results_table_id
LARK_SETTINGS_TABLE_ID=your_settings_table_id
LARK_FEED_TABLE_ID=your_feed_table_id
LARK_FEED_ARCHIVE_TABLE_ID=your_feed_archive_table_id
LARK_METRICS_TABLE_ID=your_metrics_table_id

# R2 Storage (Optional - for moodboard media uploads)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_URL=https://your-bucket.r2.dev

# Lark Moodboard Tables (Optional)
LARK_MOODBOARD_PROJECTS_TABLE_ID=your_projects_table_id
LARK_MOODBOARD_ITEMS_TABLE_ID=your_items_table_id

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Perplexity AI (Optional - for MCP)
PERPLEXITY_API_KEY=your_perplexity_key
